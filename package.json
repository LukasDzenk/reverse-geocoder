{
  "name": "reverse-geocoder",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "private": true,
  "description": "A Node.js service that maps coordinates to a city, municipality, region and country.",
  "main": "server.js",
  "author": "Lukas Dzenkauskas",
  "repository": {
    "type": "git",
    "url": "https://github.com/LukasDzenk/reverse-geocoder"
  },
  "type": "module",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "prepare": "husky || true",
    "lint": "eslint .",
    "lintQuiet": "eslint --quiet .",
    "lintFix": "eslint --fix .",
    "prettierCheck": "prettier --check .",
    "prettierWrite": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev": "NODE_ENV=development nodemon --watch \"*.ts\" --exec \"ts-node\" ./src/server.ts",
    "build": "tsc",
    "start": "NODE_ENV=production DEBUG=local-reverse-geocoder node --max-old-space-size=8192 ./dist/server.js"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "nodemon": "^3.0.1",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status-codes": "^2.2.0",
    "local-reverse-geocoder": "^0.16.5",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  }
}
