# Dependencies and build output (rebuilt inside the image)
node_modules
dist
coverage

# Local/editor cruft
.idea
.vscode
.cache
.git
.gitignore
.editorconfig

# Docker bits (don't recursively COPY into the build context)
Dockerfile*
docker-compose*
.dockerignore

# Docs and license
readme.md
LICENSE

# Local secrets
.env
.env.*
!.env.example

# Tests aren't needed at runtime
coverage*
